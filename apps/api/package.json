{
  "name": "@job-hunter/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "eval:ai": "node --import tsx test/evals/ai-eval.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@job-hunter/shared": "workspace:*",
    "pg": "^8.16.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "@types/node": "^22.14.0",
    "tsx": "^4.19.3"
  }
}
